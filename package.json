{
  "name": "gridsense",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "backend": "cd backend && uvicorn main:app --reload --port 8000",
    "frontend": "cd frontend && npm run dev",
    "start": "concurrently -n backend,frontend -c blue,green \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
